# Dependencies
node_modules/

# Netlify internal folder (this is the one we talked about!)
.netlify/

# Environment variables (secrets)
.env

# Firebase service account key (NEVER commit — contains production secrets)
service-account.json

# Firebase
.firebase/
firebase-debug.log
ui-debug.log
firestore-debug.log
storage-debug.log
emulator-data/
firebase-export-*/

# Local emulator rules (open rules, emulator only — never deploy)
*.rules.local

# VS Code workspace settings
.vscode/

# VS Code agent customization files (local only)
.github/agents/

# OS generated files (Mac/Windows hidden files)
.DS_Store
Thumbs.db
