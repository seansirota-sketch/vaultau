rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    match /authorized_users/{email} {
      allow read: if isLoggedIn() && request.auth.token.email.lower() == email.lower();
      allow list, create, update, delete: if isAdmin();
    }

    match /access_requests/{requestId} {
      allow create: if true;
      allow read, list, update, delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isLoggedIn() && request.auth.uid == userId);
      allow write: if isLoggedIn() && request.auth.uid == userId;
    }

    match /questionVotes/{questionId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    match /settings/{docId} {
      allow read: if docId == 'api_keys' ? isAdmin() : isLoggedIn();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isLoggedIn();
      allow read, list, update, delete: if isAdmin();
    }

    match /folders/{folderId} {
      allow read, list: if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
