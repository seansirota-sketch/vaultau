rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    match /courses/{courseId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();

      // Canonical, course-scoped topic taxonomy. Students read (to render topic
      // filters), only admins curate. Reset wipes this subcollection.
      match /topics/{topicId} {
        allow read: if isLoggedIn();
        allow write: if isAdmin();
      }
    }

    // Hierarchical topic categorization of questions / clauses (סעיפים).
    // One doc per assignment target with a deterministic id:
    //   "{examId}__{questionId}"              → question-level  (scope 'question')
    //   "{examId}__{questionId}__{clauseId}"  → clause-level    (scope 'clause')
    // The either/or invariant (never both scopes for one question) is enforced
    // by the admin write path in a single batch — rules can't span docs.
    match /topic_assignments/{assignmentId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();

      // Lecturers assigned to an exam may toggle ONLY the `hiddenFromStudents`
      // flag on it. They cannot edit any other field.
      allow update: if isLoggedIn()
        && resource.data.assignedLecturers is list
        && request.auth.uid in resource.data.assignedLecturers
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['hiddenFromStudents']);
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isLoggedIn() && request.auth.uid == userId);

      // Students can update only safe fields on their own document.
      // role, uid, email, and analyticsConsent are BLOCKED from self-admin-writes.
      allow update: if isLoggedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'uid', 'email']);

      // Admins can update any user document EXCEPT analyticsConsent and consentAuditLog
      // (IRB protection — only the user themselves can grant, revoke, or audit their consent).
      allow update: if isAdmin()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['analyticsConsent', 'consentAuditLog']);

      // New user document creation — force role to 'student' so nobody
      // can create their doc with role:'admin' on first login.
      allow create: if isLoggedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'student';

      // Admins can delete user documents from the admin panel (מעקב משתמשים).
      // Note: this only removes the Firestore profile, NOT the Firebase Auth account.
      allow delete: if isAdmin();

      // AI task results written by background function (Admin SDK).
      match /ai_tasks/{taskId} {
        allow read: if isLoggedIn() && request.auth.uid == userId;
      }

      // Research grade submissions — student full CRUD on own, admin read-only.
      match /user_grades/{gradeId} {
        allow read, create, update, delete: if isLoggedIn() && request.auth.uid == userId;
        allow read: if isAdmin();
      }
    }

    // Analytics events — append-only with strict server-side validation.
    // uid ownership enforced, server timestamp required, payload bounded.
    match /analytics_events/{eventId} {
      allow create: if isLoggedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.timestamp == request.time
        && request.resource.data.event is string
        && request.resource.data.event.size() < 100
        && request.resource.data.payload is map
        && request.resource.data.payload.size() <= 10
        && request.resource.data.expiresAt is timestamp;
      allow read, list: if isAdmin();
      allow delete: if isAdmin();
    }

    // block delete & raw set — votes are aggregate counters.
    // Allow both legacy bucket fields and numeric aggregate fields.
    match /questionVotes/{questionId} {
      allow read: if isLoggedIn();
      allow create, update: if isLoggedIn()
        && request.resource.data.keys().hasOnly([
          'easy', 'medium', 'hard', 'unsolved',
          'voteCount', 'ratingSum', 'averageRating'
        ]);
      allow delete: if isAdmin();
    }

    // Video explanations — any logged-in user can read, only admins can write.
    match /question_videos/{questionId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Lecturer-uploaded video submissions awaiting admin review.
    // - Lecturer can read their own submissions; admin can read all.
    // - Writes are server-only (Netlify functions via Admin SDK), never from
    //   the client, so we deny client writes entirely.
    match /video_submissions/{submissionId} {
      allow read: if isAdmin()
        || (isLoggedIn() && resource.data.uploadedByUid == request.auth.uid);
      allow write: if false;
    }

    // block delete — prevent cache wiping; create/update needed client-side.
    match /ai_questions_cache/{docId} {
      allow read: if isLoggedIn();
      allow create, update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // Allow non-admin users to read only public runtime settings in global doc.
    // Keep sensitive docs (for example api_keys) admin-only.
    match /settings/{docId} {
      allow read: if isAdmin() || (isLoggedIn() && docId == 'global');
      allow write: if isAdmin();
    }

    // enforce userId matches authenticated user to prevent forged reports.
    match /reports/{reportId} {
      allow create: if isLoggedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.status == 'open'
        && request.resource.data.category in ['contact', 'bug', 'video_bug', 'lecturer_delete_request', 'lecturer_video_submission']
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && request.resource.data.keys().hasAll([
          'category', 'message',
          'userId', 'userEmail',
          'createdAt', 'status',
          'adminResponseText', 'adminResponseAt',
          'userLastReadAt', 'adminDeletedAt', 'userDeletedAt', 'bothDeletedAt'
        ])
        && request.resource.data.size() <= 30;
      allow read, list: if isAdmin() || (isLoggedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (
        isLoggedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['userLastReadAt', 'userDeletedAt', 'bothDeletedAt'])
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['bothDeletedAt'])
          || (
            resource.data.adminDeletedAt is timestamp
            && resource.data.bothDeletedAt == null
            && request.resource.data.diff(resource.data).changedKeys().hasAll(['userDeletedAt', 'bothDeletedAt'])
          )
        )
      );
      allow delete: if isAdmin();
    }

    // Per-user AI generation quota (daily/weekly counters).
    match /user_quotas/{userId} {
      allow read: if isLoggedIn() && request.auth.uid == userId;
      allow create: if isLoggedIn() && request.auth.uid == userId;
      // day-rollover must reset requests_today to exactly 1
      // to prevent quota bypass by repeatedly changing date_key with counter=0.
      allow update: if isLoggedIn() && request.auth.uid == userId
        && (
          (request.resource.data.date_key == resource.data.date_key
            && request.resource.data.requests_today >= resource.data.requests_today)
          ||
          (request.resource.data.date_key != resource.data.date_key
            && request.resource.data.requests_today == 1)
        );
    }

    // AI generation usage logs (analytics / cost tracking).
    match /generate_usage/{docId} {
      allow create: if isLoggedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
    }

    // Question quality ratings (thumbs up/down).
    // uid ownership enforced on both create and update.
    match /question_ratings/{docId} {
      allow create: if isLoggedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isLoggedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
    }

    // Approved parse examples used for few-shot prompting.
    match /parse_examples/{docId} {
      allow read, write: if isAdmin();
    }

    // Optional exports for fine-tune/open-model workflows.
    match /model_training_exports/{docId} {
      allow read, write: if isAdmin();
    }

    // LTI identity links and launch diagnostics.
    match /lti_users/{docId} {
      allow read, write: if isAdmin();
    }

    match /lti_course_map/{docId} {
      allow read, write: if isAdmin();
    }

    match /lti_launch_audit/{docId} {
      allow read, write: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────────────────
    // Crowdsourced difficulty — Research Ledger + Aggregates
    // See docs/architecture-telemetry-difficulty-admin.md §2.5, §2.6, §4.1
    // ────────────────────────────────────────────────────────────────────────

    // Raw individual ratings. Deterministic doc ID "{itemId}_{uid}" is what
    // enforces one-vote-per-item — a second create for the same item collides
    // with the user's own doc and can only be updated by the same user.
    match /difficulty_ledger/{docId} {
      allow create: if isLoggedIn()
        && docId == request.resource.data.itemId + '_' + request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.itemType in ['exam', 'question']
        && request.resource.data.keys().hasOnly([
             'itemId','itemType','examId','questionId','courseId',
             'uid','rating','prevRating','createdAt','updatedAt','context'])
        && request.resource.data.keys().hasAll([
             'itemId','itemType','examId','courseId',
             'uid','rating','createdAt','updatedAt'])
        && (
             !('context' in request.resource.data)
             || (request.resource.data.context is map
                 && request.resource.data.context.size() <= 5)
           );

      allow update: if isLoggedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.itemType == resource.data.itemType
        && request.resource.data.examId == resource.data.examId
        && request.resource.data.courseId == resource.data.courseId
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.prevRating == resource.data.rating
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow read: if isAdmin()
        || (isLoggedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Client-read, server-write-only. The ONLY difficulty document clients render.
    match /difficulty_aggregates/{itemId} {
      allow read: if isLoggedIn();
      allow write: if false;
    }

    // ────────────────────────────────────────────────────────────────────────
    // Dual-tier telemetry — hard boundary
    // See docs/architecture-telemetry-difficulty-admin.md §2.3, §4.1
    // ────────────────────────────────────────────────────────────────────────

    // Tier 1: universal, anonymous. Auth required to control abuse, but ANY
    // identity-carrying key (uid/email/userId) is a hard reject.
    match /telemetry_t1/{eventId} {
      allow create: if isLoggedIn()
        && !request.resource.data.keys().hasAny(['uid','email','userId'])
        && request.resource.data.timestamp == request.time
        && request.resource.data.event is string
        && request.resource.data.event.size() > 0
        && request.resource.data.event.size() < 100
        && request.resource.data.payload is map
        && request.resource.data.payload.size() <= 10
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.sessionSalt is string
        && request.resource.data.sessionSalt.size() >= 16;
      allow read, list: if isAdmin();
      allow update, delete: if false;
    }

    // Tier 2: opt-in behavioural detail. Consent enforced via custom auth
    // claim (fast path) with user-doc fallback for the token-refresh window.
    match /telemetry_t2/{eventId} {
      allow create: if isLoggedIn()
        && request.resource.data.uid == request.auth.uid
        && (
             (request.auth.token.consentT2 != null
              && request.auth.token.consentT2.v is string
              && request.resource.data.consentVersion == request.auth.token.consentT2.v)
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.analyticsConsent == true
           )
        && request.resource.data.timestamp == request.time
        && request.resource.data.event is string
        && request.resource.data.event.size() > 0
        && request.resource.data.event.size() < 100
        && request.resource.data.payload is map
        && request.resource.data.payload.size() <= 20
        && request.resource.data.expiresAt is timestamp;
      allow read, list: if isAdmin();
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────────────────
    // Admin read-view projections & audit log (server-written only)
    // See docs/architecture-telemetry-difficulty-admin.md §2.7, §2.8
    // ────────────────────────────────────────────────────────────────────────

    match /popularity_stats/{itemId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admin_dashboard/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /audit_log/{eventId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }

    // Pre-computed analytics aggregates written by Cloud Function.
    // Admin: full read/write. Instructor: read only.
    match /research_stats/{docId} {
      allow read: if isAdmin() || (
        isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor'
      );
      allow write: if isAdmin();
    }

    // Broadcast messages from admin to users.
    // Any logged-in user can read; only admins can create/update/delete.
    match /broadcasts/{broadcastId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // CATCH-ALL: deny everything not explicitly matched above.
    // Any new collection MUST get its own explicit rule above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
