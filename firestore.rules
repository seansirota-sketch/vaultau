rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    match /authorized_users/{email} {
      allow read: if isLoggedIn() && request.auth.token.email.lower() == email.lower();
      allow list, create, update, delete: if isAdmin();
    }

    match /access_requests/{requestId} {
      allow create: if false;
      allow read, list, update, delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isLoggedIn() && request.auth.uid == userId);

      // Students can update only safe fields on their own document.
      // The critical fields role, uid, and email are BLOCKED from self-writes.
      allow update: if isLoggedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'uid', 'email']);

      // Admins can update any user document (they need to manage roles)
      allow update: if isAdmin();

      // New user document creation — force role to 'student' so nobody
      // can create their doc with role:'admin' on first login
      allow create: if isLoggedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'student';

      // AI task results written by background function (Admin SDK)
      // Users can only read their own tasks
      match /ai_tasks/{taskId} {
        allow read: if isLoggedIn() && request.auth.uid == userId;
      }
    }

    // FIX 1: block delete & raw set — votes are aggregate counters
    match /questionVotes/{questionId} {
      allow read: if isLoggedIn();
      allow create, update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // FIX 2: block delete — prevent cache wiping; create/update needed client-side
    match /ai_questions_cache/{docId} {
      allow read: if isLoggedIn();
      allow create, update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // FIX 4: enforce userId matches authenticated user to prevent forged reports
    match /reports/{reportId} {
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow read, list, update, delete: if isAdmin();
    }
    
    // Per-user AI generation quota (daily/weekly counters)
    match /user_quotas/{userId} {
      allow read: if isLoggedIn() && request.auth.uid == userId;
      allow create: if isLoggedIn() && request.auth.uid == userId;
      // FIX 3: day-rollover must reset requests_today to exactly 1
      // to prevent quota bypass by repeatedly changing date_key with counter=0
      allow update: if isLoggedIn() && request.auth.uid == userId
        && (
          (request.resource.data.date_key == resource.data.date_key
            && request.resource.data.requests_today >= resource.data.requests_today)
          ||
          (request.resource.data.date_key != resource.data.date_key
            && request.resource.data.requests_today == 1)
        );
    }

    // AI generation usage logs (analytics / cost tracking)
    match /generate_usage/{docId} {
      allow create: if isLoggedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
    }

    // FIX 5: Question quality ratings (thumbs up/down)
    // uid ownership enforced on both create and update.
    // NOTE: one-rating-per-question cannot be fully enforced by rules alone;
    // full enforcement requires /question_ratings/{userId}/{questionId} subcollection.
    match /question_ratings/{docId} {
      allow create: if isLoggedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isLoggedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
    }
  }
}
